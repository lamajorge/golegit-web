# ─────────────────────────────────────────────────────────────
# GoLegit — Variables de entorno
# Copia este archivo como .env.local y completa los valores
# ─────────────────────────────────────────────────────────────

# Notion CMS
# Base de datos creada: "Novedades — CMS" en Web golegit.cl
# https://www.notion.so/b844dffae5ca4ee8983d5ee3d098a70b

# 1. Ve a https://www.notion.so/my-integrations → "New integration"
# 2. Nombre: "GoLegit Web", tipo: Internal, workspace: el tuyo
# 3. Copia el "Internal Integration Secret" aquí:
NOTION_TOKEN=secret_xxxxxxxxxxxx

# 4. Comparte la base de datos con la integración:
#    Abre la BD en Notion → ··· → Connections → busca "GoLegit Web" → Confirm
# El ID de la base de datos ya está fijo:
NOTION_DB_ID=b844dffae5ca4ee8983d5ee3d098a70b

# Supabase (URL shortener go.golegit.cl)
NEXT_PUBLIC_SUPABASE_URL=https://domdefqcsiqkdpuchjtu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
