# ─────────────────────────────────────────────────────────────
# GoLegit — Variables de entorno
# Copia este archivo como .env.local y completa los valores
# ─────────────────────────────────────────────────────────────

# Notion CMS
# 1. Ve a https://www.notion.so/my-integrations y crea una integración
# 2. Copia el "Internal Integration Secret" aquí
NOTION_TOKEN=secret_xxxxxxxxxxxx

# 3. Abre tu base de datos de Notion, ve a los 3 puntos → "Copy link to view"
#    El ID es el UUID antes del "?" en la URL
NOTION_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
